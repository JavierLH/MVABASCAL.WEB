@page "/recuperar-password"
@layout SistemaAduanero.Web.Components.Layout.LoginLayout
@using SistemaAduanero.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager NavManager

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark text-center">
                <h4>Recuperar Contraseña</h4>
            </div>
            <div class="card-body">
                <p class="text-muted small">Ingresa tu correo electrónico. Si existe en nuestro sistema, te enviaremos un enlace para restablecer tu clave.</p>

                @if (enviado)
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle"></i> @mensaje
                    </div>
                    <button class="btn btn-secondary w-100" @onclick='() => NavManager.NavigateTo("/login")'>Volver al Login</button>
                }
                else
                {
                    <div class="mb-3">
                        <label>Correo Electrónico</label>
                        <input @bind="modelo.Email" class="form-control" placeholder="usuario@empresa.com" />
                    </div>

                    <button class="btn btn-primary w-100" @onclick="EnviarSolicitud" disabled="@cargando">
                        @if (cargando)
                        {
                            <span>Enviando...</span>
                        }
                        else
                        {

                            <span>Enviar Enlace</span>
                        }
                    </button>

                    <div class="mt-3 text-center">
                        <a href="login" class="text-decoration-none small">Cancelar y volver</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private SolicitarRecuperacionDto modelo = new();
    private bool cargando = false;
    private bool enviado = false;
    private string mensaje = "";

    private async Task EnviarSolicitud()
    {
        if (string.IsNullOrWhiteSpace(modelo.Email)) return;

        cargando = true;
        try
        {
            var respuesta = await Http.PostAsJsonAsync("api/Auth/solicitar-recuperacion", modelo);
            // Sin importar si existe o no, mostramos éxito por seguridad (Regla RF-08)
            enviado = true;
            mensaje = "Si el correo es válido, recibirás instrucciones en breve.";
        }
        catch (Exception)
        {
            mensaje = "Error de conexión. Intenta más tarde.";
        }
        finally
        {
            cargando = false;
        }
    }
}