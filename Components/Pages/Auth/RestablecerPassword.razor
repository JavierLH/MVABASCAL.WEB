@page "/restablecer-password"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@layout SistemaAduanero.Web.Components.Layout.LoginLayout
@using SistemaAduanero.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager NavManager

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-primary text-white text-center">
                <h4>Crear Nueva Contraseña</h4>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div class="alert alert-danger">@mensajeError</div>
                }

                @if (exito)
                {
                    <div class="alert alert-success">Tu contraseña ha sido actualizada correctamente.</div>
                    <button class="btn btn-primary w-100" @onclick='() => NavManager.NavigateTo("/login")'>Ir a Iniciar Sesión</button>
                }
                else
                {
                    <div class="mb-3">
                        <label>Nueva Contraseña</label>
                        <input @bind="modelo.NuevoPassword" type="password" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label>Confirmar Contraseña</label>
                        <input @bind="modelo.ConfirmarPassword" type="password" class="form-control" />
                    </div>

                    <button class="btn btn-success w-100" @onclick="CambiarClave" disabled="@cargando">
                        @if (cargando)
                        {
                            <span>Procesando...</span>
                        }
                        else
                        {

                            <span>Actualizar Contraseña</span>
                        }
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string Token { get; set; } = ""; // Blazor captura el ?token=... de la URL aquí automáticamente

    private RestablecerPasswordDto modelo = new();
    private string mensajeError = "";
    private bool exito = false;
    private bool cargando = false;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Token))
        {
            mensajeError = "Enlace inválido. No se encontró el token de seguridad.";
        }
        modelo.Token = Token;
    }

    private async Task CambiarClave()
    {
        cargando = true;
        mensajeError = "";

        if (modelo.NuevoPassword != modelo.ConfirmarPassword)
        {
            mensajeError = "Las contraseñas no coinciden.";
            cargando = false;
            return;
        }

        try
        {
            var respuesta = await Http.PostAsJsonAsync("api/Auth/restablecer-password", modelo);
            if (respuesta.IsSuccessStatusCode)
            {
                exito = true;
            }
            else
            {
                var error = await respuesta.Content.ReadAsStringAsync();
                mensajeError = $"Error: {error}";
            }
        }
        catch (Exception ex)
        {
            mensajeError = "Error al conectar con el servidor.";
        }
        finally
        {
            cargando = false;
        }
    }
}