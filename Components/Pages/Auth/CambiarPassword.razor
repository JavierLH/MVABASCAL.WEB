@page "/cambiar-password"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using SistemaAduanero.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager NavManager

<div class="container-fluid mt-4">

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-2">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-shield-lock-fill fs-5"></i>
                <h6 class="mb-0 fw-bold text-uppercase">SEGURIDAD DE LA CUENTA</h6>
            </div>
        </div>

        <div class="card-body p-4">

            @if (exito)
            {
                <div class="alert alert-success d-flex align-items-center" role="alert">
                    <i class="bi bi-check-circle-fill fs-4 me-2"></i>
                    <div><strong>¡Excelente!</strong> Tu contraseña ha sido actualizada correctamente.</div>
                </div>
            }

            @if (!string.IsNullOrEmpty(mensajeError))
            {
                <div class="alert alert-danger d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-triangle-fill fs-4 me-2"></i>
                    <div>@mensajeError</div>
                </div>
            }

            <p class="text-muted mb-4">
                Utiliza este formulario para actualizar tu contraseña de acceso. Asegúrate de usar una clave segura.
            </p>

            <form @onsubmit="GuardarCambios">
                <div class="row">
                    <div class="col-md-6 col-lg-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Contraseña Actual</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-key"></i></span>
                                <input @bind="modelo.PasswordActual" type="password" class="form-control" placeholder="Ingresa tu clave actual" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Nueva Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                                <input @bind="modelo.NuevoPassword" type="password" class="form-control" placeholder="Mínimo 8 caracteres" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Confirmar Nueva Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-lock-fill"></i></span>
                                <input @bind="modelo.ConfirmarPassword" type="password" class="form-control" placeholder="Repite la nueva clave" required />
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm" disabled="@cargando">
                                @if (cargando)
                                {
                                    <span><span class="spinner-border spinner-border-sm me-2"></span> Guardando...</span>
                                }
                                else
                                {
                                    <span><i class="bi bi-save me-1"></i> ACTUALIZAR CONTRASEÑA</span>
                                }
                            </button>
                            <button type="button" class="btn btn-light border text-secondary px-3" @onclick='() => NavManager.NavigateTo("/")'>
                                CANCELAR
                            </button>
                        </div>

                    </div>

                    <div class="col-md-6 col-lg-5 offset-lg-1 d-none d-md-block border-start ps-5">
                        <h6 class="text-primary fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Recomendaciones de Seguridad</h6>
                        <ul class="text-muted small">
                            <li class="mb-2">Utiliza al menos 8 caracteres.</li>
                            <li class="mb-2">Combina letras mayúsculas, minúsculas y números.</li>
                            <li class="mb-2">No utilices datos personales obvios (como tu fecha de nacimiento).</li>
                            <li class="mb-2">Cambia tu contraseña periódicamente.</li>
                        </ul>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@code {
    private CambiarPasswordDto modelo = new();
    private bool cargando = false;
    private bool exito = false;
    private string mensajeError = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Http.GetAsync("api/Auth/ping");
        }
        catch (Exception) { /* Ignorado, el DelegatingHandler se encarga del 401 */ }
    }

    private async Task GuardarCambios()
    {
        cargando = true;
        mensajeError = "";
        exito = false;

        // Validaciones básicas
        if (string.IsNullOrWhiteSpace(modelo.PasswordActual) || string.IsNullOrWhiteSpace(modelo.NuevoPassword))
        {
            mensajeError = "Todos los campos son obligatorios.";
            cargando = false;
            return;
        }

        if (modelo.NuevoPassword != modelo.ConfirmarPassword)
        {
            mensajeError = "Las nuevas contraseñas no coinciden.";
            cargando = false;
            return;
        }

        try
        {
            var respuesta = await Http.PostAsJsonAsync("api/Auth/cambiar-password", modelo);

            if (respuesta.IsSuccessStatusCode)
            {
                exito = true;
                modelo = new CambiarPasswordDto();
            }
            else
            {
                var error = await respuesta.Content.ReadAsStringAsync();
                if (error.Contains("traceId") || error.Contains("{"))
                    mensajeError = "La contraseña actual es incorrecta o no cumple los requisitos.";
                else
                    mensajeError = error.Trim('"');
            }
        }
        catch (Exception)
        {
            mensajeError = "No se pudo conectar con el servidor.";
        }
        finally
        {
            cargando = false;
        }
    }
}