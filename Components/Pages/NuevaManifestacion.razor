    private bool mostrarModalDocumentos = false;

    private int DocumentosTotales => manifestacion.Documentos.Count(d => d.EsObligatorioCatalogo && !d.Exento);
    private int DocumentosCargados => manifestacion.Documentos.Count(d => d.EsObligatorioCatalogo && !d.Exento && !string.IsNullOrEmpty(d.NombreArchivo));
    private int DocumentosExentos => manifestacion.Documentos.Count(d => d.Exento);
    private int ProgresoExpediente
    {
        get
        {
            if (manifestacion.Documentos == null || !manifestacion.Documentos.Any()) return 0;

            var requeridos = manifestacion.Documentos.Count(d => d.EsObligatorioCatalogo && !d.Exento);

            if (requeridos == 0) return 100; // Si todo está exento o no hay obligatorios, 100%

            var cargados = manifestacion.Documentos.Count(d => d.EsObligatorioCatalogo && !d.Exento && !string.IsNullOrEmpty(d.NombreArchivo));

            return (int)((double)cargados / requeridos * 100);
        }
    }

