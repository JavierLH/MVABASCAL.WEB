    private async Task SubirPdfProforma()
    {
        if (archivoPdfProforma == null) return;

        cargandoProforma = true;
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            var stream = archivoPdfProforma.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");
            content.Add(fileContent, "archivo", archivoPdfProforma.Name);

            var response = await Http.PostAsync("api/utilidades/parsear-pdf", content);

            if (response.IsSuccessStatusCode)
            {
                proformaExtraida = await response.Content.ReadFromJsonAsync<PedimentoProformaDto>();

                // SOLUCIÓN 1: Solo consultamos la BD si estamos editando (Id tiene valor).
                if (Id.HasValue)
                {
                    var res = await Http.GetFromJsonAsync<ManifestacionDto>($"api/ManifestacionesValor/{Id.Value}");
                }

                // 2. CONSULTA AL ENDPOINT DE CLIENTES (Lista Simple)
                var clientes = await Http.GetFromJsonAsync<List<ClienteDto>>("api/clientes/lista-simple");

                // 3. Buscar si el RFC extraído del PDF existe en nuestra base de datos
                var clienteBD = clientes?.FirstOrDefault(c =>
                    c.RFC?.Trim().ToUpper() == proformaExtraida.RfcImportador?.Trim().ToUpper());

                if (clienteBD != null)
                {
                    // Validar si el usuario actual tiene asignado este cliente
                    var clienteEncontrado = ListaMisClientes?.FirstOrDefault(c => c.ClienteId == clienteBD.ClienteId);

                    if (clienteEncontrado == null)
                    {
                        await MostrarToast("Error: El cliente/importador de este pedimento no está asignado a tu usuario.", SweetAlertIcon.Error);
                        return; // Detiene la carga de los datos del PDF y va al finally
                    }

                    // 4. Asignación de valores al modelo de la vista
                    manifestacion.RfcImportador = proformaExtraida.RfcImportador;
                    manifestacion.ReferenciaAdmin = proformaExtraida.NumeroPedimento;
                    manifestacion.Referencia = proformaExtraida.Referencia;

                    // Actualizamos el Select y la información del Cliente
                    OnClienteSeleccionado(clienteEncontrado.ClienteId);

                    // Totales globales
                    if (!string.IsNullOrEmpty(proformaExtraida.ValorAduana) && decimal.TryParse(proformaExtraida.ValorAduana, out decimal valorAduana))
                    {
                        manifestacion.TotalValorAduana = valorAduana;
                    }

                    if (!string.IsNullOrEmpty(proformaExtraida.PrecioPagado) && decimal.TryParse(proformaExtraida.PrecioPagado, out decimal precioPagado))
                    {
                        manifestacion.TotalPrecioPagado = precioPagado;
                    }

                    if (proformaExtraida.Incrementales != null && proformaExtraida.Incrementales.Length > 0)
                    {
                        decimal incFletes = 0, incSeguros = 0, incEmbalajes = 0, incOtros = 0;
                        if (proformaExtraida.Incrementales.Length > 0) decimal.TryParse(proformaExtraida.Incrementales[0], out incFletes);
                        if (proformaExtraida.Incrementales.Length > 1) decimal.TryParse(proformaExtraida.Incrementales[1], out incSeguros);
                        if (proformaExtraida.Incrementales.Length > 2) decimal.TryParse(proformaExtraida.Incrementales[2], out incEmbalajes);
                        if (proformaExtraida.Incrementales.Length > 3) decimal.TryParse(proformaExtraida.Incrementales[3], out incOtros);
                        
                        manifestacion.TotalIncrementables = incFletes + incSeguros + incEmbalajes + incOtros;
                    }

                    if (proformaExtraida.Decrementables != null && proformaExtraida.Decrementables.Length > 0)
                    {
                        decimal decFletes = 0, decSeguros = 0, decEmbalajes = 0, decOtros = 0;
                        if (proformaExtraida.Decrementables.Length > 0) decimal.TryParse(proformaExtraida.Decrementables[0], out decFletes);
                        if (proformaExtraida.Decrementables.Length > 1) decimal.TryParse(proformaExtraida.Decrementables[1], out decSeguros);
                        if (proformaExtraida.Decrementables.Length > 2) decimal.TryParse(proformaExtraida.Decrementables[2], out decEmbalajes);
                        if (proformaExtraida.Decrementables.Length > 3) decimal.TryParse(proformaExtraida.Decrementables[3], out decOtros);
                        
                        manifestacion.TotalDecrementables = decFletes + decSeguros + decEmbalajes + decOtros;
                    }

                    // =========================================================
                    // 5. NUEVO: AGREGAR LOS COVES EXTRAÍDOS A LA LISTA
                    // =========================================================

                    manifestacion.Coves ??= new List<CoveDetalleDto>();

                    if (proformaExtraida.Anexos != null)
                    {
                        foreach (var anexo in proformaExtraida.Anexos)
                        {
                            if (!string.IsNullOrWhiteSpace(anexo.COVE) && 
                                !manifestacion.Coves.Any(c => c.NumeroCove?.Trim().ToUpper() == anexo.COVE.Trim().ToUpper()))
                            {
                                var nuevoCove = new CoveDetalleDto
                                {
                                    IdTemporal = Guid.NewGuid().ToString(),
                                    NumeroCove = anexo.COVE.Trim(),
                                    NumeroPedimento = anexo.NumeroFactura?.Trim(), // FACTURA
                                    Incoterm = proformaExtraida.Incoterm,
                                    ExisteVinculacion = (!string.IsNullOrWhiteSpace(proformaExtraida.Vinculacion) && proformaExtraida.Vinculacion.Trim().ToUpper() == "SI"),
                                    Aduana = defaultAduana,
                                    Patente = defaultPatente,
                                    PreciosPagados = new(),
                                    PreciosPorPagar = new(),
                                    Compensaciones = new(),
                                    Incrementables = new(),
                                    Decrementables = new()
                                };

                                if (!string.IsNullOrWhiteSpace(anexo.MetodoValoracion))
                                {
                                    if (int.TryParse(anexo.MetodoValoracion, out int index) && index > 0 && index <= ListaMetodosValoracion.Count)
                                    {
                                        nuevoCove.MetodoValoracion = ListaMetodosValoracion[index - 1].Clave;
                                    }
                                    else
                                    {
                                        var metodoVal = ListaMetodosValoracion.FirstOrDefault(m => m.Clave?.Trim().ToUpper() == anexo.MetodoValoracion.Trim().ToUpper());
                                        if (metodoVal != null)
                                        {
                                            nuevoCove.MetodoValoracion = metodoVal.Clave;
                                        }
                                    }
                                }

                                manifestacion.Coves.Add(nuevoCove);
                            }
                        }
                    }
                    // =========================================================

                    await MostrarToast($"Encontrado: {clienteEncontrado.RazonSocial}", SweetAlertIcon.Success);
                }
                else
                {
                    await MostrarToast("RFC extraído pero no encontrado en el catálogo de clientes registra el cliente.", SweetAlertIcon.Warning);
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await MostrarToast("Error al parsear PDF: " + error, SweetAlertIcon.Error);
            }
        }
        catch (Exception ex)
        {
            await MostrarToast("Error: " + ex.Message, SweetAlertIcon.Error);
        }
        finally
        {
            cargandoProforma = false;
            StateHasChanged();
        }
    }

    // private void GuardarCoveEnLista() { if (coveEnEdicion != null) { var i = manifestacion.Coves.IndexOf(coveEnEdicion); if (i != -1) manifestacion.Coves[i] = coveTemporal; } else { manifestacion.Coves.Add(coveTemporal); } CerrarModal(); }
    private async Task GuardarCoveEnLista()
    {
        // 1. Validaciones mínimas de UI
        if (string.IsNullOrEmpty(coveTemporal.NumeroCove))
        {
            await MostrarToast("El número de COVE es obligatorio.", SweetAlertIcon.Warning);
            return;
        }

        // Si el expediente NO existe aún (es nuevo y nunca se ha guardado),
        // no podemos guardar el COVE en BD porque no tiene papá.
        // En ese caso, mantenemos la lógica de memoria.
        if (!Id.HasValue)
        {
            // Lógica antigua (Solo memoria)
            if (coveEnEdicion != null)
            {
                var i = manifestacion.Coves.IndexOf(coveEnEdicion);
                if (i != -1) manifestacion.Coves[i] = coveTemporal;
            }
            else
            {
                manifestacion.Coves.Add(coveTemporal);
            }
            CerrarModal();
            await MostrarToast("COVE agregado (Guardar el expediente para confirmar en BD).", SweetAlertIcon.Info);
            return;
        }

        // 2. GUARDADO TRANSACCIONAL (Directo a BD)
        try
        {
            // Vinculamos con el expediente actual
            coveTemporal.ManifestacionId = Id.Value;

            HttpResponseMessage resp;
            bool esNuevo = coveTemporal.CoveId == 0;

            if (esNuevo)
            {
                // POST: Crear
                resp = await Http.PostAsJsonAsync("api/Coves", coveTemporal);
            }
            else
            {
                // PUT: Actualizar
                resp = await Http.PutAsJsonAsync($"api/Coves/{coveTemporal.CoveId}", coveTemporal);
            }

            if (resp.IsSuccessStatusCode)
            {
                await MostrarToast(esNuevo ? "COVE creado correctamente." : "COVE actualizado correctamente.", SweetAlertIcon.Success);

                // 3. CERRAR Y RECARGAR
                // Recargamos todo el expediente desde el servidor para traer los datos frescos
                // y asegurar que la tabla principal coincida con la BD.
                CerrarModal();
                await CargarExpediente(Id.Value);
            }
            else
            {
                var errorMsg = await resp.Content.ReadAsStringAsync();
                await MostrarToast("Error al guardar COVE: " + errorMsg, SweetAlertIcon.Error);
            }
        }
        catch (Exception ex)
        {
            await MostrarToast("Error de conexión: " + ex.Message, SweetAlertIcon.Error);
        }
    }
    //private void EliminarCove(CoveDetalleDto item) => manifestacion.Coves.Remove(item);

    private void AgregarPagado() 
    {
        if (tempPagado.TipoPago == "FORPAG.OT" && string.IsNullOrWhiteSpace(tempPagado.DescripcionOtroPago))
        {
            MostrarToast("Debe especificar el tipo de pago.", SweetAlertIcon.Warning);
            return;
        }
        if (tempPagado.Total == 0 || !tempPagado.FechaPago.HasValue || string.IsNullOrEmpty(tempPagado.TipoMoneda) || tempPagado.TipoCambio<=0 || string.IsNullOrEmpty(tempPagado.TipoPago) )
        {

            MostrarToast("Debes completar todos los campos", SweetAlertIcon.Warning);
            return;

        }
        if (pagadoEnEdicion != null)
        {
            // === MODO EDICIÓN: ACTUALIZAMOS EL EXISTENTE ===

            // Buscamos el objeto original en la lista y actualizamos sus valores
            pagadoEnEdicion.FechaPago = tempPagado.FechaPago;
            pagadoEnEdicion.Total = tempPagado.Total;
            pagadoEnEdicion.TipoMoneda = tempPagado.TipoMoneda;
            pagadoEnEdicion.TipoCambio = tempPagado.TipoCambio;
            pagadoEnEdicion.TipoPago = tempPagado.TipoPago;
            pagadoEnEdicion.DescripcionOtroPago = tempPagado.DescripcionOtroPago;

            MostrarToast("Pago actualizado correctamente", SweetAlertIcon.Success);

            // Importante: Soltamos la referencia para salir del modo edición
            pagadoEnEdicion = null;
        }
        else
        {
            // === MODO CREACIÓN: AGREGAMOS UNO NUEVO ===
            coveTemporal.PreciosPagados.Add(tempPagado);
            MostrarToast("Nuevo precio pagado agregado", SweetAlertIcon.Success);
        }

       
        tempPagado = new() 
        {
            TipoMoneda = "",
