                <div class="modal-body bg-light">

                    @* --- ZONA DE CARGA --- *@
                    <div class="p-4 border rounded bg-white text-center shadow-sm mb-3">
                        <i class="bi bi-cloud-upload text-primary mb-3" style="font-size: 2.5rem;"></i>
                        <h6 class="fw-bold text-secondary mb-2">Cargar PDF Pedimento</h6>
                        <p class="text-muted small mb-3">Seleccione el archivo PDF del pedimento para extraer los datos.</p>

                        <div class="d-flex justify-content-center align-items-center gap-3">
                            <InputFile class="form-control form-control-sm" style="max-width: 320px;"
                                       accept=".pdf"
                                       OnChange="OnPdfSeleccionado" />
                            <button type="button" class="btn btn-primary btn-sm fw-bold px-3"
                                    @onclick="SubirPdfProforma"
                                    disabled="@(archivoPdfProforma == null || cargandoProforma)">
                                @if (cargandoProforma)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    <span>Procesando...</span>
                                }
                                else
                                {
                                    <i class="bi bi-search"></i>
                                    <span> Extraer Datos</span>
                                }
                            </button>
                        </div>
                    </div>

                   

                </div>
                <div class="modal-footer bg-light border-top-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CerrarModalProforma">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

