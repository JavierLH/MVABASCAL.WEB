    private async Task SubirArchivoDesdeComponente((DocumentoExpedienteDto Doc, InputFileChangeEventArgs Args) data)
    {
        if (!Id.HasValue)
        {
            await MostrarToast("Primero guarda la manifestación para poder subir archivos.", SweetAlertIcon.Warning);
            return;
        }

        var archivo = data.Args.File;
        long maxFileSize = 1024 * 1024 * 10; // 10MB Mínimo subida de original

        try
        {
            await MostrarToast("Procesando documento VUCEM...", SweetAlertIcon.Info);

            using var content = new MultipartFormDataContent();

            content.Add(new StringContent(Id.Value.ToString()), "manifestacionId");
            content.Add(new StringContent(data.Doc.AnexoId.ToString()), "anexoId");

            var fileContent = new StreamContent(archivo.OpenReadStream(maxFileSize));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(archivo.ContentType);

            content.Add(fileContent, "archivo", archivo.Name);

            var response = await Http.PostAsync("api/Documentos/subir", content);

            if (response.IsSuccessStatusCode)
            {
                var docActualizado = await response.Content.ReadFromJsonAsync<DocumentoExpedienteDto>();

                if (docActualizado != null)
                {
                    data.Doc.AnexoId = docActualizado.AnexoId;
                    data.Doc.NombreArchivo = docActualizado.NombreArchivo;
                    data.Doc.UrlDescarga = docActualizado.UrlDescarga; 
                    data.Doc.FechaCarga = docActualizado.FechaCarga;
                    data.Doc.Revisado = false; 

                    await MostrarToast("Archivo optimizado y subido correctamente", SweetAlertIcon.Success);
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await MostrarToast("Error al procesar: " + error, SweetAlertIcon.Error);
            }
        }
        catch (Exception ex)
        {
            await MostrarToast("Error: " + ex.Message, SweetAlertIcon.Error);
        }
    }

