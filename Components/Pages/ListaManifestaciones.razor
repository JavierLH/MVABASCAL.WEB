@page "/manifestaciones"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using SistemaAduanero.Shared.DTOs
@using SistemaAduanero.Shared.DTOs.SistemaAduanero.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager NavManager
@inject SweetAlertService Swal
@attribute [Authorize]
@inject IJSRuntime JS

<div class="container-fluid mt-4">

    @* === 1. HEADER ESTILIZADO (RF-07 ESTILO VISUAL) === *@
    @* === 1. HEADER HERO AZUL (ESTILO UNIFICADO) === *@
    <div class="card bg-primary text-white shadow-sm border-0 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center py-3">

            @* Lado Izquierdo: Icono y Títulos *@
            <div class="d-flex align-items-center gap-3">
                @* El círculo se queda blanco, el icono azul: Crea un contraste perfecto *@
                <div class="bg-white p-3 rounded-circle shadow-sm text-primary d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                    <i class="bi bi-folder2-open fs-3"></i>
                </div>

                <div>
                    <h6 class="fw-bold text-uppercase mb-1 text-white">Expedientes de Valor</h6>
                    <div class="d-flex gap-3 small text-white-50">
                        <span><i class="bi bi-list-ul me-1"></i> Listado General</span>
                        @if (respuesta != null)
                        {
                            <span><i class="bi bi-database me-1"></i> @respuesta.TotalRegistros Registros</span>
                        }
                    </div>
                </div>
            </div>

            @* Lado Derecho: Botón (visible para todos los roles) *@
            <button class="btn btn-light fw-bold text-primary shadow-sm px-4" @onclick="IrANueva">
                <i class="bi bi-plus-lg me-2"></i> Nuevo Expediente
            </button>
        </div>
    </div>


    @* === 2. FILTROS DE BÚSQUEDA === *@
    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Fecha Inicio</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtros.FechaInicio" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Fecha Fin</label>
                    <input type="date" class="form-control form-control-sm" @bind="filtros.FechaFin" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted text-uppercase">Búsqueda Rápida</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" class="form-control border-start-0 bg-light"
                               placeholder="Pedimento / Cliente / Referencia"
                               @bind="filtros.BusquedaTexto"
                               @bind:event="oninput"
                               @onkeyup="@(e => { if (e.Key == "Enter") CargarDatos(1); })" />
                    </div>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-secondary btn-sm w-100 fw-bold" @onclick="() => CargarDatos(1)">
                        FILTRAR
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* === 3. TABLA DE RESULTADOS === *@
    @if (respuesta == null)
    {
        <div class="d-flex justify-content-center p-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (respuesta.Elementos.Count == 0)
    {
        <div class="alert alert-light text-center shadow-sm border-0 py-5">
            <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
            <h6 class="fw-bold text-muted">No se encontraron expedientes.</h6>
            <p class="text-muted small mb-0">Intenta ajustar los filtros de fecha o búsqueda.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0 small align-middle">
                        <thead class="table-light text-uppercase text-muted" style="font-size: 0.75rem;">
                            <tr>
                                <th class="ps-4 py-3">Pedimento / Referencia</th>
                                <th class="py-3">Cliente</th>
                                <th class="py-3">Valor Aduana</th>
                                <th class="text-center py-3" style="width: 160px;">Progreso (Docs)</th>
                                <th class="text-center py-3">Estatus captura</th>
                                <th class="text-center py-3">Registro</th>
                                <th class="text-center py-3 pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in respuesta.Elementos)
                            {
                                <tr>
                                    @* Columna Doble: Pedimento (Principal) y Referencia (Secundaria) *@
                                    <td class="ps-4">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold text-primary fs-6">@item.NumeroPedimento</span>
                                            @if (!string.IsNullOrEmpty(item.Referencia))
                                            {
                                                <small class="text-muted text-uppercase" style="font-size: 0.7rem;">REF: @item.Referencia</small>
                                            }
                                            else
                                            {
                                                <small class="text-muted fst-italic" style="font-size: 0.7rem;">-- Sin Ref --</small>
                                            }
                                        </div>
                                    </td>

                                    <td class="fw-bold text-dark">@item.RazonSocial</td>

                                    <td class="fw-bold text-dark">
                                        @((item.TotalValorAduana ?? 0))
                                    </td>

                                    @* Barra de Progreso *@
                                    <td class="align-middle">
                                        <div class="d-flex align-items-center justify-content-center gap-2">
                                            <div class="progress flex-grow-1 shadow-sm bg-secondary bg-opacity-10 rounded-pill" style="height: 6px; max-width: 100px;">
                                                <div class="progress-bar rounded-pill @ObtenerColorBarra(item.Progreso)"
                                                     role="progressbar"
                                                     style="width: @(item.Progreso)%; transition: width 0.5s ease;">
                                                </div>
                                            </div>
                                            <span class="small fw-bold text-muted" style="font-size: 0.7rem; width: 35px;">
                                                @item.Progreso%
                                            </span>
                                        </div>
                                    </td>

                                    @* Estatus (Badges Suaves) *@
                                    <td class="text-center">
                                        @if (item.EstadoEnvio == "COMPLETO")
                                        {
                                            <span class="badge bg-success bg-opacity-25 text-success border border-success rounded-pill px-3">Completo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning bg-opacity-25 text-warning border border-warning rounded-pill px-3">Borrador</span>
                                        }
                                    </td>

                                    <td class="text-center text-muted">
                                        @item.FechaRegistro?.ToShortDateString()
                                    </td>

                                    @* Acciones (Estilo Limpio) *@
                                    <td class="text-center pe-4">
                                        @* Ver Detalle *@
                                        <button class="btn btn-link btn-sm text-info p-0 me-2" @onclick="() => AbrirModalDetalle(item)" title="Ver Detalle">
                                            <i class="bi bi-eye"></i>
                                        </button>

                                        @* Editar *@
                                        <button class="btn btn-link btn-sm text-primary p-0 me-2" @onclick="() => Editar(item.ManifestacionId)" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>

                                        @* Eliminar *@
                                        <button class="btn btn-link btn-sm text-danger p-0" @onclick="() => Eliminar(item)" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* Paginador *@
            <div class="card-footer bg-white py-3 border-top-0 d-flex justify-content-between align-items-center">
                <small class="text-muted">
                    Mostrando @respuesta.Elementos.Count de <strong>@respuesta.TotalRegistros</strong>
                </small>

                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(filtros.Pagina == 1 ? "disabled" : "")">
                            <button class="page-link border-0 bg-light text-dark mx-1 rounded" @onclick="() => CargarDatos(filtros.Pagina - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        <li class="page-item disabled">
                            <span class="page-link border-0 bg-white text-muted">
                                Página @filtros.Pagina de @respuesta.TotalPaginas
                            </span>
                        </li>
                        <li class="page-item @(filtros.Pagina >= respuesta.TotalPaginas ? "disabled" : "")">
                            <button class="page-link border-0 bg-light text-dark mx-1 rounded" @onclick="() => CargarDatos(filtros.Pagina + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }
</div>
@* --- MODAL DE DETALLE / RESUMEN (SOLO LECTURA - RF-07) --- *@
@if (mostrarModalDetalle && manifestacionSeleccionada != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-file-text me-2"></i> Resumen de Manifestación de Valor
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalDetalle" aria-label="Close"></button>
                </div>

                <div class="modal-body bg-light">
                    @* --- SECCIÓN 1: DATOS DE LA MANIFESTACIÓN DE VALOR --- *@
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-white py-2">
                            <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-info-circle-fill"></i> DATOS DE LA MANIFESTACIÓN DE VALOR</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold text-muted">RFC DEL IMPORTADOR</label>
                                    <div class="form-control form-control-sm bg-white border-0 fw-bold">@(manifestacionSeleccionada.RfcImportador ?? "N/A")</div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold text-muted">NOMBRE O RAZÓN SOCIAL</label>
                                    <div class="form-control form-control-sm bg-white border-0 fw-bold text-primary">@(manifestacionSeleccionada.RazonSocial ?? "N/A")</div>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small fw-bold text-muted">REFERENCIA</label>
                                    <div class="form-control form-control-sm bg-white border-0 fw-bold">@(manifestacionSeleccionada.Referencia ?? "N/A")</div>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold text-muted">NO. PEDIMENTO</label>
                                    <div class="form-control form-control-sm bg-white border-0 fw-bold text-primary">@manifestacionSeleccionada.NumeroPedimento</div>
                                </div>
                            </div>
                        </div>
                    </div>


                    @* --- SECCIÓN 2: TOTALES --- *@
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-white py-2">
                            <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-calculator-fill"></i> VALOR EN ADUANA (TOTALES)</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold text-muted">PRECIO PAGADO</label>
                                    <div class="form-control form-control-sm bg-white border-0 text-end">@((manifestacionSeleccionada.TotalPrecioPagado ?? 0).ToString("C2"))</div>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold text-muted">PRECIO POR PAGAR</label>
                                    <div class="form-control form-control-sm bg-white border-0 text-end">@((manifestacionSeleccionada.TotalPrecioPorPagar ?? 0).ToString("C2"))</div>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold text-muted">INCREMENTABLES</label>
                                    <div class="form-control form-control-sm bg-white border-0 text-end">@((manifestacionSeleccionada.TotalIncrementables ?? 0).ToString("C2"))</div>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold text-muted">DECREMENTABLES</label>
                                    <div class="form-control form-control-sm bg-white border-0 text-end">@((manifestacionSeleccionada.TotalDecrementables ?? 0).ToString("C2"))</div>
                                </div>

                                <div class="col-md-12 mt-3">
                                    <div class="p-2 rounded bg-success bg-opacity-10 border border-success d-flex justify-content-between align-items-center">
                                        <span class="ps-2 fw-bold text-success">TOTAL VALOR ADUANA</span>
                                        <span class="pe-2 fw-bold text-success fs-5">@((manifestacionSeleccionada.TotalValorAduana ?? 0).ToString("C2"))</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* --- SECCIÓN 3: PERSONAS CONSULTA --- *@
                    @if (manifestacionSeleccionada.Consultas != null && manifestacionSeleccionada.Consultas.Any())
                    {
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-header bg-white py-2">
                                <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-people-fill"></i> RFC's DE CONSULTA</h6>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-sm table-striped mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-3">RFC</th>
                                            <th>TIPO DE FIGURA</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var rfc in manifestacionSeleccionada.Consultas)
                                        {
                                            <tr>
                                                <td class="ps-3 fw-bold">@rfc.RfcConsulta</td>
                                                <td><span class="badge bg-light text-secondary border">@rfc.TipoFigura</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    @* --- SECCIÓN 4: DOCUMENTOS COVE --- *@
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-white py-2">
                            <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-file-earmark-text-fill"></i> DOCUMENTOS COVE</h6>
                        </div>
                        <div class="card-body p-3">
                            @if (manifestacionSeleccionada.ManifestacionCoves == null || !manifestacionSeleccionada.ManifestacionCoves.Any())
                            {
                                <div class="alert alert-light text-center mb-0 p-3 text-muted">
                                    No hay documentos COVE registrados para esta manifestación.
                                </div>
                            }
                            else
                            {
                                <div class="accordion" id="accordionCoves">
                                    @{
                                        int coveIndex = 0;
                                    }
                                    @foreach (var cove in manifestacionSeleccionada.ManifestacionCoves)
                                    {
                                        var currentIndex = coveIndex; // Guardamos índice local para el clic
                                        var isExpanded = activeCoveIndex == currentIndex;
                                        <div class="accordion-item border mb-2 rounded overflow-hidden">
                                            <h2 class="accordion-header">
                                                <button class="accordion-button bg-light text-dark fw-bold py-2 @(isExpanded ? "" : "collapsed")" type="button" @onclick="() => ToggleCove(currentIndex)">
                                                    COVE: <span class="text-primary ms-2">@cove.NumeroCove</span>
                                                    <span class="ms-auto me-3 small text-muted fw-normal">Incoterm: @(cove.Incoterm ?? "N/A") | Aduana: @(cove.Aduana ?? "N/A")</span>
                                                </button>
                                            </h2>
                                            <div class="accordion-collapse collapse @(isExpanded ? "show" : "")">
                                                <div class="accordion-body bg-white p-3">

                                                    @* COVE: Información Acuse de Valor y Pedimentos *@
                                                    <h6 class="text-secondary fw-bold border-bottom pb-1"><i class="bi bi-info-square me-1"></i> Información Acuse de Valor</h6>
                                                    <div class="row g-3 mb-4 bg-light p-3 rounded border">
                                                        <div class="col-md-3">
                                                            <label class="form-label small fw-bold text-muted mb-0">NÚMERO COVE</label>
                                                            <div class="fw-bold text-dark fs-6">@(cove.NumeroCove ?? "N/A")</div>
                                                        </div>
                                                        <div class="col-md-3">
                                                            <label class="form-label small fw-bold text-muted mb-0">MÉTODO VALORACIÓN ADUANERA</label>
                                                            <div class="fw-bold text-dark fs-6">@(cove.MetodoValoracion ?? "N/A")</div>
                                                        </div>
                                                        <div class="col-md-3">
                                                            <label class="form-label small fw-bold text-muted mb-0">INCOTERM</label>
                                                            <div class="fw-bold text-dark fs-6">@(cove.Incoterm ?? "N/A")</div>
                                                        </div>
                                                        <div class="col-md-3">
                                                            <label class="form-label small fw-bold text-muted mb-0">¿EXISTE VINCULACIÓN?</label>
                                                            <div class="fw-bold text-dark fs-6">@(cove.ExisteVinculacion == true ? "SÍ" : "NO")</div>
                                                        </div>
                                                    </div>

                                                    <h6 class="text-secondary fw-bold border-bottom pb-1"><i class="bi bi-file-earmark-check me-1"></i> Pedimentos</h6>
                                                    <div class="row g-3 mb-4 bg-light p-3 rounded border">
                                                        <div class="col-md-4">
                                                            <label class="form-label small fw-bold text-muted mb-0">PEDIMENTO</label>
                                                            <div class="fw-bold text-dark fs-6">@(cove.NumeroPedimento ?? "N/A")</div>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <label class="form-label small fw-bold text-muted mb-0">PATENTE</label>
                                                            <div class="fw-bold text-dark fs-6">@(cove.Patente ?? "N/A")</div>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <label class="form-label small fw-bold text-muted mb-0">ADUANA</label>
                                                            <div class="fw-bold text-dark fs-6">@(cove.Aduana ?? "N/A")</div>
                                                        </div>
                                                    </div>



                                                    @* COVE: Listas Apiladas (Sustituyendo las Tabs) *@
                                                    @* Sección Pagados *@
                                                    @if (cove.PreciosPagados != null && cove.PreciosPagados.Any())
                                                    {
                                                        <div class="mt-4 mb-3">
                                                            <h6 class="text-primary fw-bold border-bottom pb-1"><i class="bi bi-cash-coin me-1"></i> Precio pagado <span class="badge bg-secondary ms-1">@(cove.PreciosPagados.Count)</span></h6>
                                                            <div class="table-responsive">
                                                                <table class="table table-sm small table-bordered mb-0">
                                                                    <thead class="table-light"><tr><th>Fecha de pago</th><th>Forma de pago</th><th>Tipo de moneda</th><th>Tipo de cambio</th><th class="text-end">Importe</th></tr></thead>
                                                                    <tbody>
                                                                        @foreach (var p in cove.PreciosPagados)
                                                                        {
                                                                            <tr><td>@p.FechaPago?.ToShortDateString()</td><td>@p.TipoPago @(!string.IsNullOrEmpty(p.DescripcionOtroPago) ? $"({p.DescripcionOtroPago})" : "")</td><td>@p.TipoMoneda</td><td>@p.TipoCambio</td><td class="text-end">@p.Total.ToString("N2")</td></tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    }

                                                    @* Sección Por Pagar *@
                                                    @if (cove.PreciosPorPagar != null && cove.PreciosPorPagar.Any())
                                                    {
                                                        <div class="mt-4 mb-3">
                                                            <h6 class="text-danger fw-bold border-bottom pb-1"><i class="bi bi-clock-history me-1"></i> Precio por pagar <span class="badge bg-secondary ms-1">@(cove.PreciosPorPagar.Count)</span></h6>
                                                            <div class="table-responsive">
                                                                <table class="table table-sm small table-bordered mb-0">
                                                                    <thead class="table-light"><tr><th>Fecha de pago</th><th>Forma de pago</th><th>Tipo de moneda</th><th>Tipo de cambio</th><th class="text-end">Importe</th><th>Momento(s) o situación</th></tr></thead>
                                                                    <tbody>
                                                                        @foreach (var p in cove.PreciosPorPagar)
                                                                        {
                                                                            <tr><td>@p.FechaPago?.ToShortDateString()</td><td>@p.TipoPago</td><td>@p.TipoMoneda</td><td>@p.TipoCambio</td><td class="text-end">@p.Total.ToString("N2")</td><td>@p.SituacionNoFechaPago</td></tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    }

                                                    @* Sección Compensaciones *@
                                                    @if (cove.Compensaciones != null && cove.Compensaciones.Any())
                                                    {
                                                        <div class="mt-4 mb-3">
                                                            <h6 class="text-warning text-darken-3 fw-bold border-bottom pb-1"><i class="bi bi-arrow-left-right me-1"></i> Compenso pago <span class="badge bg-secondary ms-1">@(cove.Compensaciones.Count)</span></h6>
                                                            <div class="table-responsive">
                                                                <table class="table table-sm small table-bordered mb-0">
                                                                    <thead class="table-light"><tr><th>Fecha de pago</th><th>Motivo por lo que se realizó</th><th>Prestación de la mercancía</th><th>Forma de pago</th></tr></thead>
                                                                    <tbody>
                                                                        @foreach (var c in cove.Compensaciones)
                                                                        {
                                                                            <tr><td>@c.Fecha?.ToShortDateString()</td><td>@c.Motivo</td><td>@c.PrestacionMercancia</td><td>@c.TipoPago</td></tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    }

                                                    @* Sección Conceptos Valor (+/-) *@
                                                    @if (cove.ConceptosValor != null && cove.ConceptosValor.Any())
                                                    {
                                                        <div class="mt-4 mb-0">
                                                            <h6 class="text-info text-darken-2 fw-bold border-bottom pb-1"><i class="bi bi-calculator me-1"></i> Incrementables / Decrementables <span class="badge bg-secondary ms-1">@(cove.ConceptosValor.Count)</span></h6>
                                                            <div class="table-responsive">
                                                                <table class="table table-sm small table-bordered mb-0">
                                                                    <thead class="table-light"><tr><th class="text-center">+/-</th><th>Tipo</th><th>Fecha erogación</th><th class="text-end">Importe</th><th>Tipo de moneda</th><th>Tipo de cambio</th><th>¿Cargo importador?</th></tr></thead>
                                                                    <tbody>
                                                                        @foreach (var c in cove.ConceptosValor)
                                                                        {
                                                                            var isInc = c.TipoConcepto == "INCREMENTABLE";
                                                                            <tr>
                                                                                <td class="text-center @(isInc ? "text-success" : "text-danger") fw-bold fs-6">@(isInc ? "+" : "-")</td>
                                                                                <td>@c.ClaveConcepto</td>
                                                                                <td>@c.FechaErogacion?.ToShortDateString()</td>
                                                                                <td class="text-end fw-bold">@c.Importe.ToString("N2")</td>
                                                                                <td>@c.TipoMoneda</td>
                                                                                <td>@c.TipoCambio</td>
                                                                                <td>
                                                                                    @if (c.ACargoImportador == true)
                                                                                    {
                                                                                        <span class="badge bg-success">SÍ</span>
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        <span class="badge bg-secondary">NO</span>
                                                                                    }
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    }


                                                    @if ((cove.PreciosPagados == null || !cove.PreciosPagados.Any()) &&
                                                                                            (cove.PreciosPorPagar == null || !cove.PreciosPorPagar.Any()) &&
                                                                                            (cove.Compensaciones == null || !cove.Compensaciones.Any()) &&
                                                                                            (cove.ConceptosValor == null || !cove.ConceptosValor.Any()))
                                                    {
                                                        <div class="alert alert-light text-center small text-muted mt-3 mb-0 py-2 border">
                                                            No hay conceptos registrados (Pagados, Por Pagar, etc.) para este COVE.
                                                        </div>
                                                    }

                                                </div>
                                            </div>


                                        </div>
                                        coveIndex++;
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    @* --- SECCIÓN 5: EDOCUMENTS --- *@
                    @if (manifestacionSeleccionada.Edocuments != null && manifestacionSeleccionada.Edocuments.Any())
                    {
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="card-header bg-white py-2">
                                <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-file-earmark-check-fill"></i> eDOCUMENTS ASOCIADOS</h6>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-sm table-striped mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-3">NÚMERO EDOCUMENT</th>
                                            <th>DESCRIPCIÓN</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var edoc in manifestacionSeleccionada.Edocuments)
                                        {
                                            <tr>
                                                <td class="ps-3 fw-bold text-primary">@edoc.NumeroEdocument</td>
                                                <td><span class="text-secondary">@(edoc.Descripcion ?? "Sin descripción")</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>

                @* --- FOOTER: ACCIONES (RF-07) --- *@
                <div class="modal-footer bg-white border-top">
                    <button type="button" class="btn btn-outline-secondary fw-bold" @onclick="CerrarModalDetalle">
                        <i class="bi bi-x-circle me-1"></i> Cerrar
                    </button>
                    @* Este botón cumple con el requerimiento de "Se puede descargar la información en formato pdf" *@
                    <button type="button" class="btn btn-danger fw-bold shadow-sm" @onclick="DescargarPDF">
                        <i class="bi bi-file-earmark-pdf-fill me-1"></i> Descargar PDF
                    </button>
                </div>
            </div>
        </div>
    </div>
}


@code {
    //seguridad de campos
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; }
    private bool bloquearCamposAA = false;
    private PaginacionRequestDto filtros = new PaginacionRequestDto();
    private PaginacionResponseDto<ManifestacionDto>? respuesta;
    // Variables para controlar el Modal
    private bool mostrarModalDetalle = false;
    private ManifestacionDto? manifestacionSeleccionada;
    private int activeCoveIndex = 0;




    protected override async Task OnInitializedAsync()
    {
        //configuracion de seguridad
        var authState = await AuthStateTask;
        var user = authState.User;

        // Si es Cliente, activamos el bloqueo
        if (user.IsInRole("Cliente"))
        {
            bloquearCamposAA = true;
        }
        // Configuración inicial: Mostrar últimos 30 días o semana
        filtros.FechaInicio = DateTime.Today.AddDays(-5);
        filtros.FechaFin = DateTime.Today;

        await CargarDatos(1);
    }

    private async Task CargarDatos(int pagina)
    {
        try
        {
            filtros.Pagina = pagina;

            // 3. Construimos la URL con Query Strings para enviar los filtros al Controller
            // Ejemplo: api/ManifestacionesValor?Pagina=1&RegistrosPorPagina=10&FechaInicio=2024-01-01...
            var query = new List<string>
            {
                $"Pagina={filtros.Pagina}",
                $"RegistrosPorPagina={filtros.RegistrosPorPagina}"
            };

            if (filtros.FechaInicio.HasValue)
                query.Add($"FechaInicio={filtros.FechaInicio.Value:yyyy-MM-dd}");

            if (filtros.FechaFin.HasValue)
                query.Add($"FechaFin={filtros.FechaFin.Value:yyyy-MM-dd}");

            if (!string.IsNullOrEmpty(filtros.BusquedaTexto))
                query.Add($"BusquedaTexto={filtros.BusquedaTexto}");

            var url = $"api/ManifestacionesValor?{string.Join("&", query)}";

            // 4. Hacemos la petición esperando el DTO de Paginación
            respuesta = await Http.GetFromJsonAsync<PaginacionResponseDto<ManifestacionDto>>(url);
        }
        catch (Exception ex)
        {
            await MostrarToast("Error: No se pudieron cargar los datos: " + ex.Message, SweetAlertIcon.Error);
        }
    }

    private void IrANueva()
    {
        NavManager.NavigateTo("/manifestaciones/nueva");
    }

    private void Editar(int id)
    {
        NavManager.NavigateTo($"/manifestaciones/editar/{id}");
    }

    private async Task Eliminar(ManifestacionDto item)
    {
        var confirm = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "¿Estás seguro?",
            Text = $"Se eliminará el expediente {item.NumeroPedimento}.",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "Sí, eliminar",
            CancelButtonText = "Cancelar"
        });

        if (confirm.IsConfirmed)
        {
            var res = await Http.DeleteAsync($"api/ManifestacionesValor/{item.ManifestacionId}");
            if (res.IsSuccessStatusCode)
            {
                await MostrarToast("Registro eliminado.", SweetAlertIcon.Success);
                // Recargamos la misma página donde estábamos
                await CargarDatos(filtros.Pagina);
            }
            else
            {
                await MostrarToast("No se pudo eliminar.", SweetAlertIcon.Error);
            }
        }
    }

    // Método para abrir el modal desde el "ojito"
    private async Task AbrirModalDetalle(ManifestacionDto item)
    {
        try
        {
            var res = await Http.GetFromJsonAsync<ManifestacionDto>($"api/ManifestacionesValor/{item.ManifestacionId}");
            if (res != null)
            {
                manifestacionSeleccionada = res;
                activeCoveIndex = 0; // <-- AÑADE ESTA LÍNEA AQUÍ
                mostrarModalDetalle = true;
            }
            else
            {
                await MostrarToast("No se encontró el detalle de la manifestación.", SweetAlertIcon.Error);
            }
        }
        catch (Exception ex)
        {
            await MostrarToast("Error al cargar detalle: " + ex.Message, SweetAlertIcon.Error);
        }
    }

    // <-- NUEVO MÉTODO PARA ABRIR/CERRAR
    private void ToggleCove(int index)
    {
        if (activeCoveIndex == index)
            activeCoveIndex = -1; // Cierra si ya estaba abierto
        else
            activeCoveIndex = index; // Abre el nuevo listado (y cierra los demás)
    }

    // Método para cerrar el modal
    private void CerrarModalDetalle()
    {
        mostrarModalDetalle = false;
        manifestacionSeleccionada = null;
    }

    // Método para descargar el PDF (Pendiente de tu lógica de backend)
    private async Task DescargarPDF()
    {

        if (manifestacionSeleccionada != null)
        {
            var url = $"api/ManifestacionesValor/{manifestacionSeleccionada.ManifestacionId}/pdf";
            var response = await Http.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var bytes = await response.Content.ReadAsByteArrayAsync();
                var base64 = Convert.ToBase64String(bytes);
                var fileName = $"ManifestacionValor_{manifestacionSeleccionada.NumeroPedimento}.pdf";

                // Usa JS Interop para disparar la descarga en el navegador
                await JS.InvokeVoidAsync("downloadFileFromBase64", base64, fileName, "application/pdf");
            }
            else
            {
                var mensajeError = await response.Content.ReadAsStringAsync();
                await MostrarToast("Error al generar el PDF: " + mensajeError, SweetAlertIcon.Error);
            }
        }
    }

    private string ObtenerColorBarra(int p)
    {
        if (p == 100) return "bg-success"; 
        if (p >= 50) return "bg-warning";  
        return "bg-danger";                // Rojo (Incompleto 0-49%)
    }

    private async Task MostrarToast(string mensaje, SweetAlertIcon icono)
    {
        await Swal.FireAsync(new SweetAlertOptions
        {
            Toast = true,
            Position = SweetAlertPosition.TopEnd, // Arriba a la derecha
            ShowConfirmButton = false,
            Timer = 3000,
            Icon = icono,
            Title = mensaje
        });
    }
}
